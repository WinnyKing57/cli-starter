{
  "name": "cli-starter",
  "version": "1.0.0",
  "type": "module",
  "description": "A robust CLI tool to generate project boilerplates for HTML, PHP, Node.js, Express, React, and Python.",
  "main": "index.js",
  "bin": {
    "cli-starter": "bin/cli.js"
  },
  "scripts": {
    "test": "NODE_OPTIONS=--experimental-vm-modules jest --coverage",
    "lint": "eslint .",
    "format": "prettier --write .",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.js": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml}": [
      "prettier --write"
    ]
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/WinnyKing57/cli-starter.git"
  },
  "keywords": [
    "cli",
    "starter",
    "boilerplate",
    "generator",
    "template"
  ],
  "author": "",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/WinnyKing57/cli-starter/issues"
  },
  "homepage": "https://github.com/WinnyKing57/cli-starter#readme",
  "dependencies": {
    "commander": "^14.0.3",
    "inquirer": "^13.4.2",
    "tmp-promise": "^3.0.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "globals": "^17.5.0",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.3"
  }
}
